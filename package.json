{
  "name": "vite-ts-tailwind-starter",
  "version": "5.5.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env DEBUG=0 vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite-ssg build",
    "build-spa": "vite build",
    "preview": "vite-ssg build && vite preview",
    "start": "pnpm dev & wait-on tcp:3000 -v",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test-e2e": "playwright test --headed",
    "test:ci": "vitest run --coverage",
    "test:ci-e2e": "playwright test",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@fireworks-js/vue": "^2.10.8",
    "@popperjs/core": "^2.11.8",
    "@unhead/vue": "3.0.5",
    "@vueuse/motion": "3.0.3",
    "ical.js": "^2.2.1",
    "motion-v": "2.2.0",
    "pinia": "3.0.4",
    "player.style": "^0.3.1",
    "rrule": "^2.8.1",
    "v-calendar": "^3.1.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4",
    "youtube-video-element": "^1.8.0"
  },
  "devDependencies": {
    "@egoist/tailwindcss-icons": "1.9.2",
    "@iconify/json": "2.2.459",
    "@iconify/types": "2.0.0",
    "@pinia/testing": "1.0.3",
    "@playwright/test": "1.59.1",
    "@rushstack/eslint-patch": "1.16.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "24.0.4",
    "@types/jsdom": "28.0.1",
    "@types/lodash-es": "4.17.12",
    "@types/node": "~24",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/coverage-v8": "4.1.2",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "beasties": "^0.4.2",
    "cross-env": "10.1.0",
    "cssnano": "7.1.4",
    "eslint": "~9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-playwright": "2.10.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-security": "4.0.0",
    "eslint-plugin-vue": "10.9.0",
    "jsdom": "29.0.1",
    "lodash-es": "4.18.1",
    "npm-run-all2": "8.0.4",
    "postcss": "8.5.8",
    "postcss-import": "16.1.1",
    "postcss-nesting": "14.0.0",
    "prettier": "3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "unplugin-auto-import": "21.0.0",
    "unplugin-vue-components": "32.0.0",
    "vite": "8.0.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-vue-devtools": "8.1.1",
    "vite-ssg": "^28.3.0",
    "vitest": "4.1.2",
    "vue-tsc": "3.2.6",
    "wait-on": "9.0.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "eslint": "8.x"
    }
  }
}
